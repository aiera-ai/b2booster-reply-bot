# Claude API
ANTHROPIC_API_KEY=sk-ant-...

# Outflo (LinkedIn sending)
# Get from: reach.outflo.io/integration/api
OUTFLO_API_KEY=your_outflo_api_key
MY_LINKEDIN_URL=https://linkedin.com/in/zan-bagaric
VESNA_LINKEDIN_URL=https://www.linkedin.com/in/vesna-pevec-2110b8b4/

# Instantly (Email sending)
# Get from: app.instantly.ai → Settings → API
INSTANTLY_API_KEY=your_instantly_api_key
SENDING_EMAIL=zan@b2booster.si

# Resend (Approval emails)
# Free account: resend.com → API Keys
RESEND_API_KEY=re_...
BOT_FROM_EMAIL=B2Booster Bot <bot@b2booster.eu>
MY_EMAIL=zan.bagaric@gmail.com

# Netlify (Offer page deploy → ai.aiera.si)
# Get token: app.netlify.com/user/applications → Personal access tokens
NETLIFY_TOKEN=your_netlify_token
NETLIFY_SITE_ID=ed777b57-cb14-4997-91f9-733fe911fc70

# Proposal generator (NEW spirit-style, deterministic template, no prices)
# Style: spirit (default, book-meeting focus) | classic (legacy pricing offer)
PROPOSAL_STYLE=spirit
# Model used for content generation - opus-4-6 gives best Slovene quality
PROPOSAL_MODEL=claude-opus-4-6
# Subpath under NETLIFY domain (final URL: ai.aiera.si/predlog/{slug})
PROPOSAL_PREFIX=predlog
PROPOSAL_BASE_URL=https://ai.aiera.si

# Email Handoff (LinkedIn → Email)
# 15-min Calendly link used in handoff & follow-up emails
CALENDLY_AI_15MIN=https://calendly.com/aiera-koledar/aiera-ai
# From-address for handoff emails (must be a verified Resend domain)
HANDOFF_FROM_EMAIL=Žan Bagarič <zan@aiera.si>
# Days before sending 3-day follow-up to leads without booking
FOLLOWUP_DAYS=3

# Server
PORT=3000
# After Render deploy, set this to your Render URL:
SERVER_URL=https://b2booster-reply-bot.onrender.com

# ─── REVIEW IMPROVEMENTS (2026-05-23) ─────────────────────────────────────────

# Dashboard basic auth (#16). Leave empty to disable. Username irrelevant, only password is checked.
DASHBOARD_PASSWORD=

# Outbound LinkedIn throttle (#4). Max 1 LI send per account per N min. Default 20.
LI_THROTTLE_MIN=20

# Vesna → Žan handoff delay (#5). Random between MIN and MAX minutes for offer email after Vesna's LI confirm.
VESNA_HANDOFF_DELAY_MIN=60
VESNA_HANDOFF_DELAY_MAX=180

# A/B variant testing (#6). Set false to force baseline only.
AB_TEST_ENABLED=true

# Offer classifier cache (#3). Set false to always re-run AI classifier.
CLASSIFY_CACHE_ENABLED=true

# Airtable fields needed for new features (create these in Leads/Messages if missing):
#   Leads:   "Offer Type Cached" (single line text)
#            "Offer Opens" (number), "Offer Calendly Clicked" (checkbox), "Meeting Status" (single select: Shown, No Show)
#   Messages: "Variant" (single line text)
#   Proposals: "Exit Intent" (number), "Last Exit Intent At" (datetime),
#              "Pricing Dwell Bucket" (single line), "Pricing Dwell Ms" (number),
#              "Last Pricing Dwell At" (datetime), "Last Pagehide At" (datetime)
